HOST=0.0.0.0
PORT=9133

# x-ui panel URL, API token, public host, xray path, and logging are configured
# from the manager panel under Settings.

# Required before resellers can connect Telegram bot tokens.
# Use a long random value and keep it stable; changing it breaks decrypting stored bot tokens.
TELEGRAM_BOT_TOKEN_SECRET=replace-with-a-long-random-secret

# If running behind a reverse proxy instead of direct access, prefer these:
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# PORT_HEADER=x-forwarded-port
